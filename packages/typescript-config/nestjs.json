{
    "$schema": "https://json.schemastore.org/tsconfig",
    "display": "NestJS",
    "extends": "./base.json",
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2022",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "strictPropertyInitialization": false,
        "outDir": "dist",
        "baseUrl": "src"
    }
}